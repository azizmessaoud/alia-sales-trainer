# ═══════════════════════════════════════════════════
# ALIA 2.0 — Environment Configuration
# Samsung Innovation Campus SE444 | ESPRIT Tunisia
# ⚠️  NEVER commit real values — use .env.local only
# ═══════════════════════════════════════════════════

# ── Supabase Auth + PostgreSQL ──────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY
# ⚠️  service_role bypasses RLS — backend only, never client

# ── LLM Providers ───────────────────────────────────
LLM_PROVIDER=nvidia                          # nvidia | groq
NVIDIA_API_KEY=nvapi-YOUR_NVIDIA_KEY
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
GROQ_API_KEY=gsk_YOUR_GROQ_KEY               # Fallback LLM + Whisper STT

# ── TTS ─────────────────────────────────────────────
# Azure Speech (PRIMARY TTS provider — required for lip-sync)
AZURE_SPEECH_KEY=your_azure_cognitive_services_key
AZURE_SPEECH_REGION=eastus

# Language (BCP-47: en-US, fr-FR, ar-SA, es-ES)
DEFAULT_LANGUAGE=fr-FR

# ElevenLabs — REMOVED (free tier incompatible with /with-timestamps)
# ELEVENLABS_API_KEY=
HF_TOKEN=hf_YOUR_HUGGINGFACE_TOKEN          # XTTS-v2 Phase 2

# ── Feature Flags ────────────────────────────────────
USE_ELEVENLABS_STREAMING=true
USE_ELEVENLABS_LIPSYNC=true
FEATURE_MEMORY_OS=true
FEATURE_MULTIMODAL=true
FEATURE_COMPLIANCE=true
FEATURE_SCENARIOS=true
FEATURE_ORCHESTRATION=true
FEATURE_SDG_DASHBOARD=true

# ── Vector DB (Qdrant) ───────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6334                             # gRPC — 8ms vs 120ms HTTP
QDRANT_COLLECTION_PRODUCTS=alia-medical-knowledge
QDRANT_COLLECTION_MEMORY=alia-episode-memories
QDRANT_EMBEDDING_DIM=384                     # paraphrase-multilingual-MiniLM

# ── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=5173
WS_PORT=3001
WS_PING_INTERVAL=30000
SESSION_SECRET=GENERATE_WITH_openssl_rand_base64_32

# ── GPU / Inference ──────────────────────────────────
GPU_SERVER_URL=http://localhost:3000
TFJS_BACKEND=webgl

# ── Observability ────────────────────────────────────
LANGSMITH_API_KEY=ls__YOUR_LANGSMITH_KEY
LANGSMITH_PROJECT=alia-medical-training
SENTRY_DSN=https://YOUR_SENTRY_DSN