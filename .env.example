# ===================================
# ALIA 2.0 Environment Configuration
# ===================================

# -----------------
# Core Services
# -----------------

# Supabase (PostgreSQL + pgvector + Realtime)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# NVIDIA NIM (RECOMMENDED - Free Tier with Ultra-Low Latency!)
# Get free API key: https://build.nvidia.com/explore/discover
# Benefits: <50ms inference, Audio2Face lip-sync, Parakeet ASR, FastPitch TTS, Self-hosting
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
TTS_VOICE=female

# ElevenLabs TTS (primary voice provider — highest quality, multilingual)
# Sign up free: https://elevenlabs.io  |  API keys: https://elevenlabs.io/app/settings/api-keys
# Browse voices: https://elevenlabs.io/app/voice-lab  or GET https://api.elevenlabs.io/v1/voices
# Recommended female voices: Rachel (21m00Tcm4TlvDq8ikWAM), Elli (MF3mGyEYCl7XYWbV9V6O)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Recommended: Clara – Corporate & Training voice ID (copy from ElevenLabs voice library)
ELEVENLABS_VOICE_ID=your_clara_corporate_voice_id_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Default session language (BCP-47). Clients can override per session in start_session payload.
# Supported: en-US, ar-SA, fr-FR, es-ES (eleven_multilingual_v2 auto-detects — this improves accent accuracy)
DEFAULT_LANGUAGE=en-US

# OpenAI (GPT-4 + Embeddings)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------
# Optional Services
# -----------------

# Ollama (Local LLM fallback - optional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct

# -----------------
# Monitoring & Logging
# -----------------

# Sentry (Error tracking - optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Grafana Cloud (Metrics - optional)
GRAFANA_API_KEY=your-grafana-key

# -----------------
# Application Config
# -----------------

# Server
NODE_ENV=development
PORT=5173
SESSION_SECRET=your-random-secret-here-change-in-production

# WebSocket
WS_PORT=3001
WS_PING_INTERVAL=30000

# -----------------
# Feature Flags
# -----------------

# Enable/disable layers during development
FEATURE_MEMORY_OS=true
FEATURE_MULTIMODAL=true
FEATURE_COMPLIANCE=true
FEATURE_SCENARIOS=true
FEATURE_ORCHESTRATION=true
FEATURE_SDG_DASHBOARD=true

# Video processing (requires GPU)
ENABLE_VIDEO_PROCESSING=false
ENABLE_GESTURE_DETECTION=false
ENABLE_EMOTION_AI=false

# -----------------
# Performance Tuning
# -----------------

# Memory retrieval
MEMORY_SIMILARITY_THRESHOLD=0.7
MEMORY_MAX_RESULTS=5
MEMORY_CACHE_TTL=3600

# Compliance checking
COMPLIANCE_CHECK_INTERVAL=5000
COMPLIANCE_BUFFER_SIZE=50

# LLM generation
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=30000

# -----------------
# Storage
# -----------------

# File uploads (S3-compatible)
S3_BUCKET=alia-training-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key

# -----------------
# Rate Limiting
# -----------------

# API rate limits
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# OpenAI rate limits
OPENAI_RPM=3500
OPENAI_TPM=90000

# -----------------
# Security
# -----------------

# CORS
CORS_ORIGIN=http://localhost:5173,https://your-domain.com

# JWT
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here

# -----------------
# Competition Demo
# -----------------

# Demo mode (skip authentication)
DEMO_MODE=false
DEMO_REP_ID=demo-rep-123

# -----------------
# GPU Configuration
# -----------------

# GPU server (for video processing)
GPU_SERVER_URL=http://gpu-instance:5000
GPU_SERVER_API_KEY=your-gpu-api-key

# TensorFlow.js backend
TFJS_BACKEND=webgl

# -----------------
# Database
# -----------------

# Connection pooling
DB_POOL_MIN=2
DB_POOL_MAX=10

# Query timeout
DB_TIMEOUT=10000

# -----------------
# Deployment
# -----------------

# Production URLs
PUBLIC_URL=https://alia-training.com
API_URL=https://api.alia-training.com

# CDN
CDN_URL=https://cdn.alia-training.com

# -----------------
# Analytics
# -----------------

# Mixpanel (User analytics - optional)
MIXPANEL_TOKEN=your-mixpanel-token

# Google Analytics (optional)
GA_TRACKING_ID=G-XXXXXXXXXX

# -----------------
# Email (Notifications)
# -----------------

# SendGrid or similar
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@alia-training.com

# -----------------
# Competition Submission
# -----------------

COMPETITION_NAME=UN SDG AI Innovation Challenge 2026
COMPETITION_CATEGORY=Enterprise AI Training
SUBMISSION_DEADLINE=2026-03-25

# -----------------
# Notes
# -----------------

# 1. Copy this file to .env and fill in your values
# 2. NEVER commit .env to version control
# 3. For production, use environment variable management (AWS Secrets Manager, Vercel Environment Variables, etc.)
# 4. Rotate keys regularly
# 5. Use different keys for dev/staging/production

# Required for basic functionality:
# - SUPABASE_URL
# - SUPABASE_ANON_KEY
# - OPENAI_API_KEY

# Optional for advanced features:
# - VIDEO_PROCESSING requires GPU_SERVER_URL
# - MONITORING requires SENTRY_DSN
# - EMAIL requires EMAIL_API_KEY
