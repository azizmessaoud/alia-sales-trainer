# ALIA modular environment template
# Never commit real secrets. Keep actual values only in .env (local).

# Required: AI providers
OPENROUTER_API_KEY=or-YOUR_OPENROUTER_KEY
NVIDIA_API_KEY=nvapi-YOUR_NVIDIA_KEY
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Required: Azure TTS naming for modular repo
AZURE_TTS_KEY=your_azure_tts_key
AZURE_TTS_REGION=eastus

# Backward-compatible aliases used by existing STT/TTS code
AZURE_SPEECH_KEY=your_azure_tts_key
AZURE_SPEECH_REGION=eastus

# Required: data stores
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key

# Existing Qdrant compatibility keys (optional)
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION_PRODUCTS=alia-medical-knowledge
QDRANT_COLLECTION_MEMORY=alia-episode-memories
QDRANT_EMBEDDING_DIM=384

# Required integrations
EMOTION_SERVICE_URL=http://localhost:5000
EMOTION_POLL_INTERVAL_MS=0
OLLAMA_BASE_URL=http://localhost:11434

# Runtime
NODE_ENV=development
PORT=5173
WS_PORT=3001
REMIX_BACKEND_URL=http://localhost:5173
SESSION_SECRET=GENERATE_WITH_openssl_rand_base64_32
DEFAULT_LANGUAGE=fr-FR

# Optional feature and model flags
LLM_PROVIDER=nvidia
GROQ_API_KEY=gsk_YOUR_GROQ_KEY
HF_TOKEN=hf_YOUR_HUGGINGFACE_TOKEN
USE_ELEVENLABS_STREAMING=true
USE_ELEVENLABS_LIPSYNC=true
FEATURE_MEMORY_OS=true
FEATURE_MULTIMODAL=true
FEATURE_COMPLIANCE=true
FEATURE_SCENARIOS=true
FEATURE_ORCHESTRATION=true
FEATURE_SDG_DASHBOARD=true

# Optional observability
LANGCHAIN_CALLBACKS_BACKGROUND=true
LANGSMITH_API_KEY=ls__YOUR_LANGSMITH_KEY
LANGSMITH_PROJECT=alia-medical-training
SENTRY_DSN=https://YOUR_SENTRY_DSN