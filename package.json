{
  "name": "alia-medical-training",
  "version": "2.0.0",
  "description": "AI-powered medical sales training platform with agentic memory, multimodal sensing, and real-time compliance",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remix vite:dev",
    "build": "remix vite:build",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc",
    "test": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "migrate": "supabase db push",
    "seed": "tsx scripts/seed-products.ts",
    "scenario:generate": "tsx scripts/generate-test-scenarios.ts",
    "sdg:calculate": "tsx scripts/calculate-sdg-metrics.ts",
    "lint": "eslint app --max-warnings 0",
    "format": "prettier --write \"app/**/*.{ts,tsx,css,md}\"",
    "server": "node server-nvidia-nim.js",
    "server:ws": "node server-websocket.js",
    "dev:all": "concurrently \"npm run server\" \"npm run server:ws\" \"npm run dev\"",
    "ingest-vital-docs": "tsx modules/rag-memory/scripts/ingest-vital-docs.ts",
    "test-rag": "tsx modules/rag-memory/scripts/test-rag.ts"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@langchain/core": "^0.1.63",
    "@langchain/langgraph": "^0.0.12",
    "@langchain/openai": "^0.0.20",
    "@met4citizen/talkinghead": "^1.7.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@remix-run/node": "^2.8.1",
    "@remix-run/react": "^2.8.1",
    "@remix-run/serve": "^2.8.1",
    "@supabase/supabase-js": "^2.39.7",
    "@types/three": "^0.183.1",
    "date-fns": "^3.3.1",
    "groq-sdk": "^0.37.0",
    "isbot": "^5.1.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.49.0",
    "openai": "^4.28.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "three": "^0.183.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@remix-run/dev": "^2.8.1",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.56.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^1.3.1"
  },
  "optionalDependencies": {
    "@sentry/node": "^7.102.1",
    "@sentry/remix": "^7.102.1",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs": "^4.17.0",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "medical-training",
    "sales-ai",
    "agentic-ai",
    "compliance",
    "multimodal",
    "langgraph",
    "remix",
    "supabase",
    "openai",
    "gpt-4",
    "sdg",
    "un-sustainable-development-goals"
  ],
  "author": "Aziz Messaoud <aziz.messaoud@esprit.tn>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/azizmessaoud/alia.git"
  },
  "bugs": {
    "url": "https://github.com/azizmessaoud/alia/issues"
  },
  "homepage": "https://github.com/azizmessaoud/alia/tree/a"
}
