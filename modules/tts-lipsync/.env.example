# ALIA tts-lipsync module — TTS synthesis and blendshape/viseme mapping
# Only variables used by this module.

# Required: TTS provider fallback chain
AZURE_TTS_KEY=your_azure_tts_key
AZURE_TTS_REGION=eastus

# Optional: NVIDIA TTS (uses shared NVIDIA_API_KEY from root .env)
NVIDIA_API_KEY=nvapi-YOUR_NVIDIA_KEY
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: Lip-sync debug and tuning
LIP_SYNC_DEBUG=false
LIP_SYNC_VISEME_SCALE=1.0
