# ALIA ai-core module — LLM orchestration, STT, compliance, memory retrieval
# Only variables used by this module and its service facades.
# Copy to .env and fill in real values.

# Required: LLM provider selection
NVIDIA_API_KEY=nvapi-YOUR_NVIDIA_KEY
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_PROVIDER=nvidia

# Fallback LLM providers (optional)
GROQ_API_KEY=gsk_YOUR_GROQ_KEY
OPENROUTER_API_KEY=or-YOUR_OPENROUTER_KEY

# Required: Speech-to-Text (Azure)
AZURE_SPEECH_KEY=your_azure_stt_key
AZURE_SPEECH_REGION=eastus

# Required: Data stores for memory and knowledge
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY
OLLAMA_BASE_URL=http://localhost:11434

# Required: Qdrant vector store for RAG
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_PRODUCTS=alia-medical-knowledge
QDRANT_COLLECTION_MEMORY=alia-episode-memories

# Compliance and session management
FEATURE_MEMORY_OS=true
NODE_ENV=development
